# Copy this file to .env.local and fill in your values
# Get these from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_GS_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_GS_SUPABASE_ANON_KEY=your-anon-key
GS_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GS_SUPABASE_JWT_SECRET=your-jwt-secret

# Postgres (for direct queries if needed)
GS_POSTGRES_URL=postgres://...
GS_POSTGRES_URL_NON_POOLING=postgres://...
